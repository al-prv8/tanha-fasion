datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           String          @id @default(uuid())
  sku          String          @unique
  name         String
  price        Float
  category     String
  imgUrl       String
  sizesJson    String          @default("{\"S\":10,\"M\":15,\"L\":15,\"XL\":5}")
  reviews      Review[]
  orderItems   OrderItem[]
  purchases    StockPurchase[]
  createdAt    DateTime        @default(now())
}

model Order {
  id                   String      @id @default(uuid())
  orderNumber          String      @unique // e.g., TF-123456
  name                 String
  phone                String
  email                String?
  address              String
  city                 String
  postcode             String
  shippingCost         Float
  subtotal             Float
  discount             Float
  grandTotal           Float
  paymentMethod        String      // bkash, nagad, cod, card
  paymentStatus        String      @default("UNPAID") // UNPAID, PAID, REFUNDED
  orderStatus          String      @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  trxId                String?     // Transaction ID for MFS verification
  stockAdjusted        Boolean     @default(false)
  items                OrderItem[]
  courierConsignmentId String?
  courierTrackingCode  String?
  courierStatus        String?
  createdAt            DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  size      String
  quantity  Int
  price     Float
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Category {
  id                String   @id @default(uuid())
  name              String   @unique
  englishName       String?
  imgUrl            String?
  bannerUrl         String?
  order             Int      @default(0)
  bannerSubtitle    String?
  bannerDescription String?
  createdAt         DateTime @default(now())
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  type        String   // PERCENTAGE or FLAT
  value       Float
  minSubtotal Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("CUSTOMER") // "ADMIN" or "CUSTOMER"
  name      String
  phone     String?
  address   String?
  city      String?
  postcode  String?
  createdAt DateTime @default(now())
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Announcement {
  id         String   @id @default(uuid())
  text       String
  buttonText String?
  link       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminName String
  email     String
  action    String
  details   String
  createdAt DateTime @default(now())
}

model Supplier {
  id        String          @id @default(uuid())
  name      String
  phone     String?
  company   String?
  purchases StockPurchase[]
  createdAt DateTime        @default(now())
}

model StockPurchase {
  id          String    @id @default(uuid())
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        String    // S, M, L, XL, etc.
  quantity    Int
  buyingPrice Float
  totalCost   Float
  createdAt   DateTime  @default(now())
}





