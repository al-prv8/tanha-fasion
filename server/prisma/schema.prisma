datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           String      @id @default(uuid())
  sku          String      @unique
  name         String
  price        Float
  category     String
  imgUrl       String
  sizesJson    String      @default("{\"S\":10,\"M\":15,\"L\":15,\"XL\":5}")
  reviews      Review[]
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now())
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique // e.g., TF-123456
  name          String
  phone         String
  email         String?
  address       String
  city          String
  postcode      String
  shippingCost  Float
  subtotal      Float
  discount      Float
  grandTotal    Float
  paymentMethod String        // bkash, nagad, cod, card
  paymentStatus String        @default("UNPAID")    // UNPAID, PAID, REFUNDED
  orderStatus   String        @default("PENDING")   // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  trxId         String?       // Transaction ID for MFS verification
  stockAdjusted Boolean       @default(false)
  items         OrderItem[]
  createdAt     DateTime      @default(now())
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  size      String
  quantity  Int
  price     Float
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  type        String   // PERCENTAGE or FLAT
  value       Float
  minSubtotal Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

