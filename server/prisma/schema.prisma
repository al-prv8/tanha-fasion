datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id                String          @id @default(uuid())
  sku               String          @unique
  name              String
  price             Float
  category          String
  imgUrl            String
  sizesJson         String          @default("{\"S\":10,\"M\":15,\"L\":15,\"XL\":5}")
  showroomSizesJson String          @default("{\"S\":10,\"M\":15,\"L\":15,\"XL\":5}")
  sizePricesJson    String          @default("{}")
  reviews           Review[]
  orderItems        OrderItem[]
  purchases         StockPurchase[]
  branchStocks      BranchStock[]
  createdAt         DateTime        @default(now())
}

model Order {
  id                   String      @id @default(uuid())
  orderNumber          String      @unique // e.g., TF-123456
  name                 String
  phone                String
  email                String?
  address              String
  city                 String
  postcode             String
  shippingCost         Float
  subtotal             Float
  discount             Float
  grandTotal           Float
  paymentMethod        String      // bkash, nagad, cod, card
  paymentStatus        String      @default("UNPAID") // UNPAID, PAID, REFUNDED
  orderStatus          String      @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED
  trxId                String?     // Transaction ID for MFS verification
  stockAdjusted        Boolean     @default(false)
  isShowroom           Boolean     @default(false)
  branchId             String?     // Link to physical branch (null for online orders)
  branch               Branch?     @relation(fields: [branchId], references: [id])
  items                OrderItem[]
  courierConsignmentId String?
  courierTrackingCode  String?
  courierStatus        String?
  createdAt            DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  size      String
  quantity  Int
  price     Float
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

model Category {
  id                String   @id @default(uuid())
  name              String   @unique
  englishName       String?
  imgUrl            String?
  bannerUrl         String?
  order             Int      @default(0)
  bannerSubtitle    String?
  bannerDescription String?
  createdAt         DateTime @default(now())
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  type        String   // PERCENTAGE or FLAT
  value       Float
  minSubtotal Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  role           String   @default("CUSTOMER") // "SUPER_ADMIN", "BRANCH_MANAGER", "CUSTOMER" (also supports legacy "ADMIN")
  name           String
  phone          String?
  address        String?
  city           String?
  postcode       String?
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])
  allowedModules String?  @default("showroom_pos,showroom_stock,showroom_purchases,showroom_orders,showroom_expenses")
  createdAt      DateTime @default(now())
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Announcement {
  id         String   @id @default(uuid())
  text       String
  buttonText String?
  link       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminName String
  email     String
  action    String
  details   String
  createdAt DateTime @default(now())
}

model Supplier {
  id        String          @id @default(uuid())
  name      String
  phone     String?
  company   String?
  purchases StockPurchase[]
  createdAt DateTime        @default(now())
}

model StockPurchase {
  id          String    @id @default(uuid())
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  size        String    // S, M, L, XL, etc.
  quantity    Int
  buyingPrice Float
  totalCost   Float
  branchId    String?   // Target physical branch (null for online warehouse)
  branch      Branch?   @relation(fields: [branchId], references: [id])
  createdAt   DateTime  @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  category    String   // Rent, Utilities, Salary, Packaging, Entertainment, Other
  amount      Float
  description String?
  branchId    String?  // Scopes expense to branch (null for online store overhead)
  branch      Branch?  @relation(fields: [branchId], references: [id])
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Branch {
  id        String          @id @default(uuid())
  name      String          @unique // e.g., "Dhanmondi Outlet", "Mirpur Outlet"
  address   String?
  phone     String?
  city      String          @default("Dhaka")
  timings   String          @default("সকাল ১০:০০ টা - রাত ৯:০০ টা")
  holiday   String          @default("বুধবার (সাপ্তাহিক বন্ধ)")
  location  String?
  stocks    BranchStock[]
  orders    Order[]         // Orders processed at this branch
  users     User[]          // Staff scoped to this branch
  purchases StockPurchase[] // Stock purchases scoped to this branch
  expenses  Expense[]       // Expenses scoped to this branch
  createdAt DateTime        @default(now())
}

model BranchStock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sizesJson String   @default("{\"S\":0,\"M\":0,\"L\":0,\"XL\":0}")
  
  @@unique([productId, branchId])
}





